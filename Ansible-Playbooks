2) Create playbook for install httpd and print message
---
 - name: Install Apache(httpd) and print message
   hosts: all
   become: yes
   tasks:
     - name: Install Apache-httpd
       yum:
         name: httpd
         state: present
     - name: Print Message
       debug:
         msg: Installed apache
...

3) Create Playbook for Apache uninstall and print message
---
 - name: Uninstall Apache and Print Message
   hosts: all
   become: yes
   tasks:
     - name: Uninstall Apache(httpd)
       yum:
         name: httpd
         state: absent
     - name: Print Message
       debug:
         msg: uninstall apache
...

4) Create Playbook for Apache install and start and enable the service and print message
---
 - name: Install httpd and start and enable service and print message
   hosts: all
   become: yes
   tasks:
     - name: Install http
       yum:
         name: httpd
         state: present
     - name: enable service and start service
       service:
         name: httpd
         state: started
         enabled: yes
     - name: print message
       debug:
         msg: started and enable httpd
...

5) Create Playbook for Git,docker install and start and enable the service and print message
---
 - name: install git and docker and start docker service
   hosts: all
   become: yes
   tasks:
     - name: Install Git
       yum:
         name: git
         state: present
     - name: Install Docker
       yum:
         name: docker
         state: present
     - name: start docker and enable service
       service:
         name: docker
         state: started
         enabled: yes
     - name: message
       debug:
         msg: installed git and docker and start,enable service
...

