19) Create Playbook for Install httpd on redhat os and install apache2 on debian os(ubuntu) like conditions using when module
---
 - name: Install httpd on redhat os and install apache2 on debian os(ubuntu)
   hosts: all
   become: yes
   gather_facts: yes
   tasks:
     - name: Install httpd on redhat os
       yum:
         name: httpd
         state: present
       when: ansible_os_family == "RedHat"
       tags: redhat
     - name: Install apache2 on debian os
       apt:
         name: apache2
         state: present
       when: ansible_os_family == "Debian"
       tags: debian
     - name: print message
       debug:
         msg: works when redhat os means httpd installs and debian os means apache2 installs
       tags: message
...

