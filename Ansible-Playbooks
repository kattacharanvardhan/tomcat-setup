17) Create Playbook for Install httpd,docker and start immediately using notify and handlers
---
 - name: Install httpd,docker and start immediately using notify and handlers
   hosts: all
   become: yes
   gather_facts: false
   tasks:
     - name: Install httpd
       yum:
         name: httpd
         state: present
       notify: start httpd
     - name: Install docker
       yum:
         name: docker
         state: present
       notify: start docker
   handlers:
     - name: start httpd
       service:
         name: httpd
         state: started
         enabled: yes
     - name: start docker
       service:
         name: docker
         state: started
         enabled: yes
