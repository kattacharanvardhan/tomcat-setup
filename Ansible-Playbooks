22) Create Playbook for replace nginx.conf file in slave machines using jinja2 templates
vi nginx.conf.j2
server{
   listen {{nginx_value}};
   server_name {{server_name}};
   location /{
        root {{web_root}};
        index index.html;
   }
}
vi playbook.yml
---
 - name: replace nginx configuration file in slave machines(/etc/nginx/nginx.conf) using jinja2 template
   hosts: all
   become: yes
   vars:
     nginx_value: 80
     server_name: nginx-server
     web_root: /var/www/html
   tasks:
     - name: Install nginx
       yum:
         name: nginx
         state: present
     - name: Copy Nginx conf file to slave
       copy:
         src: /root/templates/nginx.conf.j2 
         dest: /etc/nginx/nginx.conf
...

