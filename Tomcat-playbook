---
- name: Install and Configure Tomcat Through Playbook in slave server
  hosts: all
  become: yes
  tasks:
    - name: Install Java
      yum:
        name: java-21-amazon-corretto
        state: present
    - name: Download Tomcat
      get_url:
        url: "https://dlcdn.apache.org/tomcat/tomcat-11/v11.0.23/bin/apache-tomcat-11.0.23.tar.gz"
        dest: /opt/apache-tomcat-11.0.23.tar.gz

    - name: Extract Tomcat
      unarchive:
        src: /opt/apache-tomcat-11.0.23.tar.gz
        dest: /opt
        remote_src: yes

    - name: Rename Tomcat Directory
      command: mv /opt/apache-tomcat-11.0.23 /opt/tomcat

    - name: Copy tomcat-users.xml
      template:
        src: tomcat-users.xml
        dest: /opt/tomcat/conf/tomcat-users.xml

    - name: Copy context.xml
      template:
        src: context.xml
        dest: /opt/tomcat/webapps/manager/META-INF/context.xml

    - name: Create Tomcat Systemd Service
      copy:
        dest: /etc/systemd/system/tomcat.service
        content: |
          [Unit]
          Description=Apache Tomcat Server
          After=network.target

          [Service]
          Type=forking
          User=root
          Group=root

          Environment=JAVA_HOME=/usr/lib/jvm/java-21-amazon-corretto
          Environment=CATALINA_HOME=/opt/tomcat

          ExecStart=/opt/tomcat/bin/startup.sh
          ExecStop=/opt/tomcat/bin/shutdown.sh

          Restart=on-failure

          [Install]
          WantedBy=multi-user.target

    - name: Reload systemd
      systemd:
        daemon_reload: yes

    - name: Start Tomcat
      service:
        name: tomcat
        state: started
        enabled: yes
...
