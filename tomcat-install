#Install wget
yum install -y wget

#search java-openjdk version
yum search openjdk

#install java
yum install java-21-openjdk java-21-openjdk-devel -y

#download tomcat internet link[ https://dlcdn.apache.org/ --> search tomcat to lastest version --> In /bin folder looks like this (apache-tomcat-<version>.tar.gz) --> copy the link address]
wget https://dlcdn.apache.org/tomcat/tomcat-11/v11.0.23/bin/apache-tomcat-11.0.23.tar.gz

#to extract the download tomcat.tar.gz file
tar -zxvf apache-tomcat-11.0.23.tar.gz

#Edit the apache-tomcat-11.0.23/conf/tomcat-users.xml in line 56 add this all 
vi apache-tomcat-11.0.23/conf/tomcat-users.xml
  <role rolename="manager-gui"/>
  <role rolename="manager-script"/>
  <user username="tomcat" password="root123456" roles="manager-gui, manager-script"/>

#delete line 21 and 22 in apache-tomcat-11.0.23/webapps/manager/META_INF
vi apache-tomcat-11.0.23/webapps/manager/META-INF/context.xml
like delete
  <Valve className="org.apache.catalina.valves.RemoteCIDRValve"
         allow="127.0.0.0/8,::1/128" />


#start tomcat
cd apache-tomcat-11.0.23/bin
sh startup.sh

